rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Providers can be read by anyone, but only edited by themselves
    match /providers/{providerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == providerId;
    }
    
    // Services are public
    match /services/{serviceId} {
      allow read: if true;
      allow write: if request.auth != null; // Simplified for this project
    }
    
    // Bookings are private to the client and provider
    match /bookings/{bookingId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.providerId);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.clientId || request.auth.uid == resource.data.providerId);
    }
  }
}
